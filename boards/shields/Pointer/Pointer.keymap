#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>

/ {
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = < 
            &lt 1 A
            &lt 2 B
            >;
        };

        rst_layer {
            bindings = < 
            &bootloader
            &none
            >;
        };

        bt_layer {
            bindings = < 
            &none
            &bt BT_CLR_ALL
            >;
        };
    };
 };